---
import Layout from "../layouts/Layout.astro";
import ExperienceItem from "../components/ExperienceItem.astro";
import { EXPERIENCE } from "../components/Experience.astro";
---

<Layout title="Trayectoria Completa - Alfonso Adiego">
  <main class="pt-32 pb-24 max-w-6xl mx-auto px-6 overflow-hidden">
    
    <!-- Botón Volver -->
    <a href="/#" class="group inline-flex items-center gap-2 text-text-muted hover:text-cyan mb-12 transition-all duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform group-hover:-translate-x-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5m7-7-7 7 7 7"/></svg>
        <span class="text-sm font-bold uppercase tracking-widest">Volver al inicio</span>
    </a>

    <h1 class="text-5xl md:text-7xl font-bold text-text-muted mb-20 tracking-tighter transition-colors duration-500">
        Experiencia <br/> <span class="animate-gradient-text">Profesional</span>
    </h1>

    <div class="relative ml-4 md:ml-12">
        
        <div class="absolute -left-px top-0 w-0.5 h-full bg-linear-to-b from-cyan via-purple to-transparent opacity-20"></div>
        
        <div id="timeline-beam" class="absolute -left-px top-0 w-0.5 h-40 bg-linear-to-b from-transparent via-cyan to-transparent shadow-[0_0_20px_#00C1FD] z-10 transition-all duration-700 ease-out opacity-0 will-change-transform"></div>

        <div class="flex flex-col gap-20">
            {EXPERIENCE.map((item) => (
                <div class="experience-node">
                    <ExperienceItem {...item} />
                </div>
            ))}
        </div>
    </div>
  </main>
</Layout>