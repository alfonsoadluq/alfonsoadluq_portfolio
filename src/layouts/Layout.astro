---
import '../styles/global.css'
import '@fontsource-variable/inter/wght.css';
import '@fontsource/poppins/500.css';

import Seo from '@components/Seo.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---
<!doctype html>
<html lang="es-ES">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<Seo title="Portfolio de Alfonso Adiego Luque - Desarrollador FullStack Junior" description="Soy Alfonso Adiego Luque, desarrollador FullStack Junior. Explora mis proyectos y descubre cómo puedo ayudarte a desarrollar tus ideas." />
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
				return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
				return 'dark';
				}
				return 'light';
			})();
			document.documentElement.setAttribute('data-theme', theme);
		</script>
	</head>
	<body>
		<div id="cursor" class="cursor"></div>
		<Header />
		<slot />
		<Footer />
		<script src="../scripts/main.ts"></script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>