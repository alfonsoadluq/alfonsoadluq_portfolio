---
import { Picture } from "astro:assets";
import { Images } from "@assets/images";
import LinkButton from "./LinkButton.astro";

// 1. CONFIGURACIÓN DE TAGS
const TAGS = {
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159]/30 text-[#44a8b3]",
    icon: Images.icons.TailWindIcon,
  },
  LARAVEL: {
    name: "Laravel",
    class: "bg-[#003159]/30 text-[#FF2D20]",
    icon: Images.icons.LaravelIcon,
  },
  REACT: {
    name: "React",
    class: "bg-[#003159]/30 text-[#61DAFB]",
    icon: Images.icons.ReactIcon,
  },
}

// 2. DATOS DE LOS PROYECTOS
const PROJECTS =[
  {
    title: "KitKeeper Refreshed",
    description: "Versión renovada del proyecto original KitKeeper de gestión de materiales tecnológicos en centros educativos. Implementación de una interfaz renovada y fluida usando React y Gsap, mejorando la experiencia del usuario y facilitando la organización de materiales para los centros educativos.",
    link: "", 
    github: "https://github.com/alfonsoadluq/kitkeeper-refreshed",
    image: Images.projects.KitKeeperPreview,
    tags: [TAGS.TAILWIND, TAGS.LARAVEL, TAGS.REACT]
  },
]
---

<!-- 3. RENDERIZADO HTML -->
<section id={`${Astro.props.id}`} class="py-24 max-w-6xl mx-auto px-6">
    <h2 class="text-4xl font-black mb-16 flex items-center gap-4 text-white tracking-tighter">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-cyan icon icon-tabler icons-tabler-filled icon-tabler-bulb"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M4 11a1 1 0 0 1 .117 1.993l-.117 .007h-1a1 1 0 0 1 -.117 -1.993l.117 -.007h1z" /><path d="M12 2a1 1 0 0 1 .993 .883l.007 .117v1a1 1 0 0 1 -1.993 .117l-.007 -.117v-1a1 1 0 0 1 1 -1z" /><path d="M21 11a1 1 0 0 1 .117 1.993l-.117 .007h-1a1 1 0 0 1 -.117 -1.993l.117 -.007h1z" /><path d="M4.893 4.893a1 1 0 0 1 1.32 -.083l.094 .083l.7 .7a1 1 0 0 1 -1.32 1.497l-.094 -.083l-.7 -.7a1 1 0 0 1 0 -1.414z" /><path d="M17.693 4.893a1 1 0 0 1 1.497 1.32l-.083 .094l-.7 .7a1 1 0 0 1 -1.497 -1.32l.083 -.094l.7 -.7z" /><path d="M14 18a1 1 0 0 1 1 1a3 3 0 0 1 -6 0a1 1 0 0 1 .883 -.993l.117 -.007h4z" /><path d="M12 6a6 6 0 0 1 3.6 10.8a1 1 0 0 1 -.471 .192l-.129 .008h-6a1 1 0 0 1 -.6 -.2a6 6 0 0 1 3.6 -10.8z" /></svg>Proyectos
    </h2>

    <div class="flex flex-col gap-y-32">
        {PROJECTS.map(({ title, description, image, tags, link, github }) => (
            <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-12 md:space-y-0 items-center">
              <div class="w-full md:w-1/2">
                <div class="card-border-glow rounded-2xl transition-all duration-500">
                  <div class="card-content overflow-hidden rounded-2xl bg-[#050b18] holographic-card relative">
                    <Picture
                      src={image}
                      alt={title}
                      formats={["avif", "webp"]}
                      widths={[400, 800, image.width]}
                      sizes={`(max-width: 768px) 100vw, 50vw`}
                      loading="lazy"
                      fetchpriority="low"
                      decoding="async"
                      class="object-cover object-top w-full h-56 md:h-[300px] transition duration-700"
                    />
                  </div>
                </div>
              </div>

              <!-- INFORMACIÓN DEL PROYECTO -->
              <div class="w-full md:w-1/2 md:max-w-lg">
                <h3 class="text-3xl font-black text-white mb-4 drop-shadow-[0_0_10px_rgba(0,193,253,0.3)]">
                  {title}
                </h3>
                
                <!-- TAGS CON ICONOS DE LOS LENGUAJES -->
                <div class="flex flex-wrap gap-2 mb-4">
                  {tags.map((tag) => (
                    <span class={`flex items-center gap-x-2 rounded-full text-[10px] font-bold uppercase tracking-wider py-1.5 px-3 border border-white/10 ${tag.class}`}>
                      <Picture
                        src={tag.icon}
                        alt={tag.name}
                        width={16}
                        height={16}
                        formats={["avif", "webp"]}
                        loading="lazy"
                        fetchpriority="low"
                        decoding="async"
                        class="w-4 h-4 object-contain"
                      />
                      {tag.name}
                    </span>
                  ))}
                </div>

                <p class="text-text-muted leading-relaxed mb-6 text-sm md:text-base">
                  {description}
                </p>

                <!-- FOOTER CON BOTONES E ICONOS -->
                <footer class="flex flex-wrap gap-4">
                  {github && (
                    <LinkButton href={github}>
                      <Picture
                        src={Images.icons.GitHubIcon}
                        alt="GitHub Logo"
                        width={20}
                        height={20}
                        formats={["avif", "webp"]}
                        loading="lazy"
                        fetchpriority="low"
                        decoding="async"
                        class="w-5 h-5 invert dark:invert-0 transition-transform group-hover:scale-110"
                      />
                      GitHub
                    </LinkButton>
                  )}
                  
                  {link && (
                    <LinkButton href={link}>
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="size-4 icon icon-tabler icons-tabler-filled icon-tabler-external-link">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                        <path d="M12 5a1 1 0 0 1 0 2h-6a1 1 0 0 0 -1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1 -1v-6a1 1 0 0 1 2 0v6a3 3 0 0 1 -3 3h-10a3 3 0 0 1 -3 -3v-10a3 3 0 0 1 3 -3zm3 -2h5l.075 .003l.126 .017l.111 .03l.111 .044l.098 .052l.096 .067l.09 .08q .054 .053 .097 .112l.071 .11l.054 .114l.035 .105l.03 .148l.006 .118v5a1 1 0 0 1 -2 0v-2.586l-7.293 7.293a1 1 0 0 1 -1.414 -1.414l7.291 -7.293h-2.584a1 1 0 0 1 0 -2" />
                      </svg>
                      Preview
                    </LinkButton>
                  )}
                </footer>
              </div>
              
            </article>
        ))}
    </div>
</section>