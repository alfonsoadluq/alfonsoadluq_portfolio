---
import { Picture } from "astro:assets";
import { Images } from "@assets/images";

const { isFull = false } = Astro.props;

interface ActionLink { label: string; href: string; }
interface Project {
  id: string;
  category: string;
  featured: boolean;
  inDevelopment: boolean;
  overline: string;
  title: string;
  description: string;
  image: any;
  accent: string;
  features: string[];
  skills: string[];
  githubLink: string | null;
  demoLink: string | null;
  actionLinks: ActionLink[];
}

const FILTERS = [
  { id: "all", title: "Todos", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>` },
  { id: "work", title: "Empresa", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>` },
  { id: "personal", title: "Personal", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0" /><path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2" /></svg>` }
];

export const PROJECTS: Project[] = [
  {
    id: "kitkeeper refreshed",
    category: "personal",
    featured: false, 
    inDevelopment: true,
    overline: "Full Stack • Inventario IT • Laravel • PostgreSQL • 2FA",
    title: "KitKeeper Refreshed",
    description: "Nueva versión del KitKeeper original, enfocada en mejorar la experiencia de usuario y las capacidades del sistema administrativo.",
    image: Images.projects.KitKeeperPreview,
    accent: "#f97316",
    features:["CONTROL DE PEDIDOS", "INFORMES DESCARGABLES", "AUTENTICACIÓN 2FA", "GESTIÓN DE USUARIOS"],
    skills: ["React Native", "Laravel", "PostgreSQL", "Tailwind CSS", "Supabase"],
    githubLink: "https://github.com/alfonsoadluq/kitkeeper-refreshed",
    demoLink: "https://alfonsoal.dev",
    actionLinks: [] // Espacio para futuras acciones como "Ver caso de estudio", "Leer artículo", etc. Su uso es mediante un objeto: { label: "Texto del botón", href: "URL a la que apunta" }
  },
  {
    id: "foody",
    category: "personal",
    featured: false, 
    inDevelopment: true,
    overline: "MOBILE • APRENDIZAJE",
    title: "Foody — Recetas",
    description: "Gestión inteligente de inventario y recetas para el hogar basándose en ingredientes disponibles.",
    image: null, 
    accent: "#00C1FD",
    features:["AUTENTICACIÓN COMPLETA", "CÁLCULO DE CANTIDADES"],
    skills: ["React Native", "Expo", "Supabase"],
    githubLink: "https://github.com/alfonsoadluq",
    demoLink: null,
    actionLinks: []
  },
    {
    id: "foody",
    category: "personal",
    featured: false, 
    inDevelopment: true,
    overline: "MOBILE • APRENDIZAJE",
    title: "Foody — Recetas",
    description: "Gestión inteligente de inventario y recetas para el hogar basándose en ingredientes disponibles.",
    image: null, 
    accent: "#00C1FD",
    features:["AUTENTICACIÓN COMPLETA", "CÁLCULO DE CANTIDADES"],
    skills: ["React Native", "Expo", "Supabase"],
    githubLink: "https://github.com/alfonsoadluq",
    demoLink: null,
    actionLinks: []
  },
    {
    id: "foody",
    category: "personal",
    featured: false, 
    inDevelopment: true,
    overline: "MOBILE • APRENDIZAJE",
    title: "Foody — Recetas",
    description: "Gestión inteligente de inventario y recetas para el hogar basándose en ingredientes disponibles.",
    image: null, 
    accent: "#00C1FD",
    features:["AUTENTICACIÓN COMPLETA", "CÁLCULO DE CANTIDADES"],
    skills: ["React Native", "Expo", "Supabase"],
    githubLink: "https://github.com/alfonsoadluq",
    demoLink: null,
    actionLinks: []
  },
];

const displayProjects = isFull ? PROJECTS : PROJECTS.slice(0, 4); // La cantidad de proyectos a mostrar
const showViewMore = !isFull && PROJECTS.length > 4; // La cantidad de proyectos a partir de la cual se muestra el botón de "Ver todos los proyectos"
---

<section id={Astro.props.id} class:list={["max-w-6xl mx-auto px-6 overflow-visible transition-all", isFull ? "pb-24 pt-0" : "py-24" ]}>
    
    <div class="flex flex-col items-start mb-20 text-center">
        { !isFull && (
            <h2 class="text-4xl md:text-5xl font-black mb-12 text-slate-900 dark:text-white tracking-tighter transition-colors flex items-center gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-cyan icon icon-tabler icons-tabler-filled icon-tabler-flask-2"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M15 2a1 1 0 0 1 0 2v5.674l.062 .03a7 7 0 0 1 3.85 5.174l.037 .262a7 7 0 0 1 -3.078 6.693a1 1 0 0 1 -.553 .167h-6.635a1 1 0 0 1 -.552 -.166a7 7 0 0 1 .807 -12.134l.062 -.028v-5.672a1 1 0 1 1 0 -2h6zm-2 2h-2v6.34a1 1 0 0 1 -.551 .894l-.116 .049a5 5 0 0 0 -2.92 2.717h9.172a5 5 0 0 0 -2.918 -2.715a1 1 0 0 1 -.667 -.943v-6.342z" /></svg>
                Proyectos
            </h2>
        )}

        <div class="flex flex-wrap justify-center gap-3 md:gap-4">
            {FILTERS.map((filter, idx) => (
                <button data-filter={filter.id} class={`project-filter-btn flex flex-col items-center justify-center gap-2 w-20 h-20 md:w-24 md:h-24 rounded-2xl md:rounded-3xl transition-all duration-300 cursor-pointer outline-none ${idx === 0 ? 'hover:bg-cyan/10 text-cyan shadow-lg scale-105' : 'bg-slate-50 dark:bg-[#050b18]/60 text-slate-500 dark:text-slate-400 hover:text-cyan'}`}>
                    <div class="w-6 h-6 md:w-7 md:h-7"><Fragment set:html={filter.icon} /></div>
                    <span class="font-black uppercase text-[10px] tracking-wide">{filter.title}</span>
                </button>
            ))}
        </div>
    </div>

    <div id="projects-grid" class="flex flex-wrap gap-8 justify-center items-start">
        {displayProjects.map((project) => (
            <article data-category={project.category} class:list={["project-card group transition-all duration-500", project.featured ? "w-full" : "w-full md:w-[calc(50%-1rem)] flex"]}>
                <div class:list={["relative flex flex-col overflow-hidden rounded-[2.5rem] border border-slate-200 dark:border-white/5 bg-white dark:bg-[#050b18]/60 backdrop-blur-md shadow-2xl transition-all w-full h-auto cursor-pointer lg:cursor-default"]}>
                    
                    <div class:list={["relative overflow-hidden shrink-0 transition-all bg-slate-900 h-64 md:h-80 w-full flex items-center justify-center"]}>
                        {project.image ? (
                            <div class="w-full h-full relative">
                                <Picture src={project.image} alt={project.title} formats={["avif", "webp"]} widths={[400, 800, 1200]} sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw" loading="lazy" class="object-cover object-top w-full h-full transition-all duration-700" />
                                <div class="absolute inset-0 bg-black/10"></div>
                            </div>
                        ) : (
                            <div class="absolute inset-0 w-full h-full flex items-center justify-center">
                                <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px); background-size: 20px 20px;"></div>
                                <div class="relative z-10 text-cyan/20 scale-[4]">
                                </div>
                            </div>
                        )}

                        <div class="absolute bottom-4 right-4 flex flex-col gap-2 z-20">
                            {project.featured && (
                                <div class="px-3 py-1.5 rounded-full bg-amber-500/20 backdrop-blur-md border border-amber-500/40 flex items-center gap-2 text-[#ffdf00] shadow-lg">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M12 17.75l-6.172 3.245 1.179-6.873-4.993-4.867 6.9-1.002L12 2l3.086 6.253 6.9 1.002-4.993 4.867 1.179 6.873z"/></svg>
                                    <span class="text-[10px] font-black uppercase tracking-widest">Destacado</span>
                                </div>
                            )}
                            {project.inDevelopment && (
                                <div class="px-3 py-1.5 rounded-full bg-blue-500/20 backdrop-blur-md border border-blue-500/40 flex items-center gap-2 text-blue-400 shadow-lg">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                                    <span class="text-[10px] font-black uppercase tracking-widest">En desarrollo</span>
                                </div>
                            )}
                        </div>

                        <div class="lg:hidden absolute bottom-4 right-4 z-20 text-cyan chevron-icon transition-transform bg-black/50 rounded-full p-1.5 border border-white/10">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                        </div>
                    </div>

                    <!-- Zona de contenido -->
                    <div class="flex flex-col p-6 md:p-8 lg:p-10 grow w-full">
                        <div>
                            <span class="text-cyan font-mono text-[9px] tracking-[0.3em] uppercase mb-2 block">{project.overline}</span>
                            <h3 class="font-black text-slate-900 dark:text-white tracking-tighter transition-colors leading-tight uppercase mb-4 text-2xl md:text-3xl lg:text-4xl">
                                {project.title}
                            </h3>
                            
                            <div class="mobile-content-wrapper">
                                <div class="overflow-hidden pt-2 lg:pt-0">
                                    <p class="text-slate-600 dark:text-slate-400 text-sm md:text-base leading-relaxed mb-6">
                                        {project.description}
                                    </p>
                                    
                                    <ul class="space-y-3 mb-6">
                                        {project.features.map(text => (
                                            <li class="flex items-center gap-3 text-[10px] md:text-xs font-black text-slate-700 dark:text-slate-200 uppercase tracking-widest transition-colors"><div class="w-1.5 h-1.5 rounded-full bg-cyan shadow-[0_0_8px_#00C1FD] shrink-0"></div><span>{text}</span></li>
                                        ))}
                                    </ul>

                                    <!-- Acciones -->
                                    <div class="mt-auto pt-5 pb-2 border-t border-slate-200 dark:border-white/5 flex flex-col gap-5">
                                        <div class="flex flex-wrap gap-2">
                                            {project.skills.map(s => <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-[9px] font-bold text-slate-600 dark:text-cyan/80 uppercase tracking-widest">{s}</span>)}
                                        </div>

                                        <div class="flex flex-wrap items-center gap-4 px-1">
                                            {project.githubLink && (
                                                <a href={project.githubLink} target="_blank" title="Ir a GitHub" aria-label="Ir a GitHub" class="group/btn relative flex items-center justify-start w-12 h-12 bg-cyan text-slate-900 rounded-full transition-all duration-500 overflow-hidden active:scale-95 hover:scale-115 p-2.5 shadow-[0_0_15px_rgba(0,193,253,0.4)]">
                                                    <div class="flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg></div>
                                                </a>
                                            )}
                                            {project.demoLink && (
                                                <a href={project.demoLink} target="_blank" title="Ver Demo" aria-label="Ver Demo" class="group/btn relative flex items-center justify-start w-12 h-12 bg-cyan text-slate-900 rounded-full transition-all duration-500 overflow-hidden active:scale-95 hover:scale-115 p-2.5 shadow-[0_0_15px_rgba(0,193,253,0.4)]">
                                                    <div class="flex items-center justify-center min-w-5">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 icon icon-tabler icons-tabler-filled icon-tabler-external-link"><path stroke="none" stroke-width="1.5" d="M0 0h24v24H0z" fill="none" /><path d="M12 5a1 1 0 0 1 0 2h-6a1 1 0 0 0 -1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1 -1v-6a1 1 0 0 1 2 0v6a3 3 0 0 1 -3 3h-10a3 3 0 0 1 -3 -3v-10a3 3 0 0 1 3 -3zm3 -2h5l.075 .003l.126 .017l.111 .03l.111 .044l.098 .052l.096 .067l.09 .08q .054 .053 .097 .112l.071 .11l.054 .114l.035 .105l.03 .148l.006 .118v5a1 1 0 0 1 -2 0v-2.586l-7.293 7.293a1 1 0 0 1 -1.414 -1.414l7.291 -7.293h-2.584a1 1 0 0 1 0 -2" /></svg></div>
                                                </a>
                                            )}
                                            {project.actionLinks.map(link => (
                                                <a href={link.href} class="flex-1 py-3 px-4 rounded-xl bg-cyan text-slate-900 text-[12px] font-black uppercase text-center active:scale-95 transition-all">{link.label}</a>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </article>
        ))}
    </div>

    {showViewMore && (
        <div class="mt-20 flex justify-center lg:justify-start">
            <a href="/AllProjects" class="group btn-cyber flex items-center gap-3 px-8 py-4 rounded-2xl font-black uppercase text-sm tracking-widest text-white shadow-lg active:scale-95 transition-all">
                Ver todos los proyectos
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
            </a>
        </div>
    )}
</section>

<style>
    #projects-grid { display: flex; flex-wrap: wrap; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .mobile-content-wrapper { display: grid; grid-template-rows: 0fr; opacity: 0; transition: grid-template-rows 0.5s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease; }
    @media (min-width: 1024px) { .mobile-content-wrapper { grid-template-rows: 1fr; opacity: 1; } }
    .project-card.is-expanded .mobile-content-wrapper { grid-template-rows: 1fr; opacity: 1; margin-top: 1rem; }
    .project-card.is-expanded .chevron-icon { transform: rotate(180deg); }
    .project-card.hidden-card { display: none; }
</style>