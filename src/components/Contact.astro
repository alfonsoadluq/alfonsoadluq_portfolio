---
import cv from "@assets/CV_Alfonso.pdf";

const buttonData = [
    {
        label: "Email",
        href: "mailto:alfonsoaldev@gmail.com",
        title: "Correo electrónico",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" /><path d="M3 7l9 6l9 -6" /></svg>`,
        hoverWidth: "hover:w-[105px]"
    },
    {
        label: "LinkedIn",
        href: "https://www.linkedin.com/in/alfonso-adiego-luque/",
        title: "LinkedIn",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z" /><path d="M8 11l0 5" /><path d="M8 8l0 .01" /><path d="M12 16l0 -5" /><path d="M16 16v-3a2 2 0 0 0 -4 0" /></svg>`,
        hoverWidth: "hover:w-[120px]"
    },
    {
        label: "GitHub",
        href: "https://github.com/alfonsoadluq",
        title: "GitHub",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg>`,
        hoverWidth: "hover:w-[115px]"
    },
    {
        label: "Currículum",
        href: cv,
        fileName: "CV_Alfonso.pdf",
        title: "Currículum",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" /><path d="M9 17h6" /><path d="M9 13h6" /></svg>`,
        hoverWidth: "hover:w-[140px]"
    }
];

// --- Cambia esto a 'true' cuando quieras mostrar el formulario ---
const showForm = false; 
---

<section id="contact" class="py-24 max-w-6xl mx-auto px-6 relative scroll-mt-20">

    <div class="flex flex-col items-center mb-16 text-center">
        <h2 class="text-5xl md:text-7xl font-black mb-6 text-slate-900 dark:text-white tracking-tighter uppercase transition-colors duration-500">
            Hablemos
        </h2>
    </div>

    <div class:list={[
        showForm ? "grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center" : "flex flex-col items-center text-center"
    ]}>
        
        <!-- Texto y botones -->
        <div class:list={[
            "flex flex-col gap-8 transition-all duration-500",
            !showForm ? "items-center max-w-3xl" : "items-start"
        ]}>
            <p class="text-slate-600 dark:text-text-muted text-xl md:text-2xl leading-relaxed transition-colors duration-500">
                ¿Necesitas ayuda para construir tu proyecto, quieres colaborar en algo o estas interesado en mis habilidades? 
                <strong class="text-slate-900 dark:text-white font-black">No dudes en contactarme.</strong>
            </p>
            
            <p class="text-slate-500 dark:text-text-muted/60 text-lg">
                Puedes hacerlo a través de mis redes y correo personal:
            </p>

            <!-- Botones -->
            <div class:list={[
                "flex flex-wrap gap-4 mt-4",
                !showForm ? "justify-center" : "justify-start"
            ]}>
                {buttonData.map((btn) => (
                    <a 
                        href={btn.href} 
                        target={btn.label !== 'Email' ? "_blank" : "_self"}
                        class={`group relative flex items-center justify-start w-12 h-12 btn-cyber text-white rounded-full transition-all duration-500 overflow-hidden ${btn.hoverWidth} p-3 active:scale-95 shadow-lg`}
                    >
                        <div class="flex items-center justify-center min-w-[24px]">
                            <Fragment set:html={btn.icon} />
                        </div>
                        <span class="ml-3 font-bold whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 uppercase text-[10px] tracking-widest">
                            {btn.label}
                        </span>
                    </a>
                ))}
            </div>
        </div>

        <!-- Formulario: Solo se renderiza si showForm es true -->
        {showForm && (
            <div class="w-full">
                <div class="card-border-glow rounded-[2.5rem] transition-all duration-500 hover:shadow-[0_0_30px_rgba(0,193,253,0.15)]">
                    <form 
                        id="contact-form"
                        action="https://formspree.io/t/12345678"
                        method="POST"
                        class="card-content-fix p-8 md:p-10 bg-slate-50 dark:bg-[#050b18]/90 backdrop-blur-xl rounded-[2.5rem] border border-slate-200 dark:border-white/5 relative overflow-hidden flex flex-col gap-6 transition-colors duration-500"
                    >
                        <div class="flex flex-col gap-2 text-left">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-500">Nombre</label>
                            <input type="text" name="name" required placeholder="Tu nombre" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:border-cyan outline-none transition-all" />
                        </div>
                        <div class="flex flex-col gap-2 text-left">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-500">Email</label>
                            <input type="email" name="email" required placeholder="tu@email.com" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:border-cyan outline-none transition-all" />
                        </div>
                        <div class="flex flex-col gap-2 text-left">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-500">Mensaje</label>
                            <textarea name="message" rows="4" required placeholder="Cuéntame más..." class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:border-cyan outline-none transition-all resize-none"></textarea>
                        </div>
                        <button type="submit" class="w-full py-4 rounded-xl bg-cyan text-white text-xs font-black uppercase tracking-[0.2em] flex items-center justify-center gap-3 hover:shadow-[0_0_20px_rgba(0,193,253,0.4)] active:scale-95 transition-all">
                            <span>Enviar Mensaje</span>
                        </button>
                    </form>
                </div>
            </div>
        )}
    </div>
</section>

<style>
    .card-content-fix {
        z-index: 1;
        position: relative;
        width: 100%;
        height: 100%;
    }
</style>