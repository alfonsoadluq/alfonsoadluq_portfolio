---
import cv from "@assets/CV_Alfonso.pdf";

const buttonData = [
    {
        label: "Email",
        href: "mailto:alfonsoaldev@gmail.com"
    },
    {
        label: "LinkedIn",
        href: "https://www.linkedin.com/in/alfonso-adiego-luque/"
    },
    {
        label: "GitHub",
        href: "https://github.com/alfonsoadluq"
    },
    {
        label: "Currículum",
        href: cv,
        fileName: "CV_Alfonso.pdf"
    }
]
---

<section id="contact" class="py-12 max-w-4xl mx-auto px-6 relative scroll-mt-35 lg:scroll-mt-18">

    <h2 class="text-5xl md:text-7xl font-black mb-8 text-slate-900 dark:text-white tracking-tighter text-center transition-colors duration-500">
        Hablemos
    </h2>

    <!-- Párrafo con enlaces integrados -->
    <p class="text-center text-text-muted text-lg md:text-xl leading-relaxed mb-16 max-w-3xl mx-auto transition-colors duration-500">
        ¡Me encantaría saber en qué estás trabajando o cómo puedo ayudarte! Escríbeme a 
        <a href={buttonData[0].href} rel="noopener noreferrer" title="Correo electrónico" aria-label="alfonsoaldev@gmail.com" class="text-cyan font-bold underline decoration-slate-300 dark:decoration-white/20 hover:decoration-cyan dark:hover:decoration-cyan hover:text-cyan dark:hover:text-cyan transition-all underline-offset-4">alfonsoaldev@gmail.com</a>, 
        búscame en 
        <a href={buttonData[1].href} target="_blank" rel="noopener noreferrer" title="LinkedIn" aria-label="LinkedIn de Alfonso Adiego Luque" class="text-cyan font-bold underline decoration-slate-300 dark:decoration-white/20 hover:decoration-cyan dark:hover:decoration-cyan hover:text-cyan dark:hover:text-cyan transition-all underline-offset-4">LinkedIn</a>, 
        o explora mi código directamente en 
        <a href={buttonData[2].href} target="_blank" rel="noopener noreferrer" title="GitHub" aria-label="GitHub de Alfonso Adiego Luque" class="text-cyan font-bold underline decoration-slate-300 dark:decoration-white/20 hover:decoration-cyan dark:hover:decoration-cyan hover:text-cyan dark:hover:text-cyan transition-all underline-offset-4">GitHub</a>.
    </p>

    <!-- Botones  -->
    <div class="flex flex-wrap justify-center gap-4 md:gap-6 mb-32">
        
        <!-- Email -->
        <a href={buttonData[0].href} rel="noopener noreferrer" title="Correo electrónico" aria-label="Correo electrónico" class="group relative flex items-center justify-start w-12 h-12 btn-cyber text-white rounded-full transition-all duration-500 overflow-hidden hover:w-30 p-3 active:scale-95 shadow-lg">
            <div class="flex items-center justify-center min-w-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
                    <path d="M3 7l9 6l9 -6" />
                </svg>
            </div>
            <span class="ml-4 font-bold whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">
                Email
            </span>
        </a>

        <!-- LinkedIn -->
        <a href={buttonData[1].href} target="_blank" rel="noopener noreferrer" title="LinkedIn" aria-label="LinkedIn de Alfonso Adiego Luque" class="group relative flex items-center justify-start w-12 h-12 btn-cyber text-white rounded-full transition-all duration-500 overflow-hidden hover:w-35 p-3 active:scale-95 shadow-lg">
            <div class="flex items-center justify-center min-w-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z" />
                    <path d="M8 11l0 5" /><path d="M8 8l0 .01" /><path d="M12 16l0 -5" /><path d="M16 16v-3a2 2 0 0 0 -4 0" />
                </svg>
            </div>
            <span class="ml-4 font-bold whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">
                LinkedIn
            </span>
        </a>

        <!-- GitHub -->
        <a href={buttonData[2].href} target="_blank" rel="noopener noreferrer" title="GitHub" aria-label="GitHub de Alfonso Adiego Luque" class="group relative flex items-center justify-start w-12 h-12 btn-cyber text-white rounded-full transition-all duration-500 overflow-hidden hover:w-31 p-3 active:scale-95 shadow-lg">
            <div class="flex items-center justify-center min-w-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
                </svg>
            </div>
            <span class="ml-4 font-bold whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">
                GitHub
            </span>
        </a>

        <!-- Currículum -->
        <a href={buttonData[3].href} download={buttonData[3].fileName} rel="noopener noreferrer" target="_blank" title="Currículum" aria-label="Currículum de Alfonso Adiego Luque" class="group relative flex items-center justify-start w-12 h-12 btn-cyber text-white rounded-full transition-all duration-500 overflow-hidden hover:w-38 p-3 active:scale-95 shadow-lg">
            <div class="flex items-center justify-center min-w-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M14 3v4a1 1 0 0 0 1 1h4" />
                    <path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" />
                    <path d="M9 17h6" /><path d="M9 13h6" />
                </svg>
            </div>
            <span class="ml-4 font-bold whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">
                Currículum
            </span>
        </a>
    </div>
</section>