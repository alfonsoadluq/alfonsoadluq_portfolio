---
import LinkButton from "./LinkButton.astro";
import { Images } from "@assets/images";

interface Props {
  title: string;
  description: string;
  image: string;
  tags: { name: string; class: string; icon: any }[];
  link?: string;
  github?: string;
}

const { title, description, image, tags, link, github } = Astro.props;
---

<article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-12 md:space-y-0 items-center">
  <!-- IMAGEN CON EFECTO NEÓN GIRATORIO -->
  <div class="w-full md:w-1/2">
    <div class="card-border-glow rounded-2xl transition-transform duration-500 group-hover:scale-[1.02]">
      <div class="card-content overflow-hidden rounded-2xl bg-[#050b18]">
        <img 
          alt={title} 
          class="object-cover object-top w-full h-56 transition duration-700 md:h-[300px] group-hover:scale-110" 
          loading="lazy" 
          src={image} 
        />
      </div>
    </div>
  </div>

  <!-- INFORMACIÓN DEL PROYECTO -->
  <div class="w-full md:w-1/2 md:max-w-lg">
    <h3 class="text-3xl font-black text-white mb-4 drop-shadow-[0_0_10px_rgba(0,193,253,0.3)]">
      {title}
    </h3>
    
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => (
        <span class={`flex items-center gap-x-2 rounded-full text-[10px] font-bold uppercase tracking-wider py-1 px-3 border border-white/10 ${tag.class}`}>
          <!-- Renderizamos el icono desde tu objeto Images -->
          <img src={tag.icon.src} class="size-4 object-contain" alt={tag.name} />
          {tag.name}
        </span>
      ))}
    </div>

    <p class="text-text-muted leading-relaxed mb-6 text-sm md:text-base">
      {description}
    </p>

    <footer class="flex flex-wrap gap-4">
      {github && (
        <LinkButton href={github}>
          <!-- Icono de GitHub desde tu objeto Images -->
          <img src={Images.icons.GitHubIcon.src} class="size-5 invert dark:invert-0" alt="GitHub" />
          Code
        </LinkButton>
      )}
      {link && (
        <LinkButton href={link}>
          <!-- Icono de link manual (SVG) ya que no existe Link.astro -->
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
          </svg>
          Preview
        </LinkButton>
      )}
    </footer>
  </div>
</article>