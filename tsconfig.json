{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["src/assets/*"],
      "@img/*": ["src/assets/img/*"],
      "@icon/*": ["src/assets/img/icons/*"],
      "@project/*": ["src/assets/img/projects/*"],
      "@components/*": ["src/components/*"]
    }
  }
}
